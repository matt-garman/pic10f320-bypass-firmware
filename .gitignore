# vim backup files
*~

# compilation artifacts
*.hex
*.elf
build_pic/

# ...EXCEPT the prebuilt release images, which ARE tracked: committing them is
# the whole point of release/ (scripts/make-release.sh stages them there). The
# global *.hex ignore above would otherwise silently drop them from `git add`.
!release/**/*.hex

# cppcheck addon artifacts (e.g. "make analyze-misra"); normally auto-cleaned,
# but a cancelled run can leave them behind
*.dump
*.ctu-info
cppcheck-addon-ctu-file-list*

# gpsim drops this log (often 0-byte) in the cwd on every "make test-gpsim"
gpsim.log

# coverage artifacts ("make coverage" / "make coverage-check")
coverage/
*.gcda
*.gcno
*.gcov

# release scaffolding: scripts/make-release.sh writes the suggested git commit
# message here for `git commit -F`. It is NOT a release artifact (it must stay
# out of release/<version>/) and must not trip the clean-tree release gate.
/commit_msg.txt

# claude code
.claude/
